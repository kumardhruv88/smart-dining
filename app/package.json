{
  "name": "smart-dining-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json -r tsconfig-paths/register server.ts",
    "start": "cross-env NODE_ENV=production ts-node --project tsconfig.server.json -r tsconfig-paths/register server.ts",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "postinstall": "node -e \"const fs=require('fs');const p='prisma';if(!fs.existsSync(p))fs.mkdirSync(p);try{fs.copyFileSync('../prisma/schema.prisma',p+'/schema.prisma')}catch(e){console.log('skip schema copy')}\"",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev --schema ../prisma/schema.prisma",
    "db:seed": "tsx ../prisma/seed.ts",
    "db:embeddings": "tsx ../prisma/generate-embeddings.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "@tanstack/react-query": "^5.45.1",
    "@tanstack/react-query-devtools": "^5.45.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.400.0",
    "next": "14.2.5",
    "openai": "^4.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^6.0.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  }
}
