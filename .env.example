# ─────────────────────────────────────────────────────────────────────────────
# Smart Dining Assistant — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API
GROQ_API_KEY=

# Supabase PostgreSQL (with pgvector)
DATABASE_URL=

# Upstash Redis
REDIS_URL=

# App URLs
NEXT_PUBLIC_APP_URL=
# Local: http://localhost:7860
# Production: https://{username}-smart-dining-ai.hf.space
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:7860

# Auth / OTP
# Provider: mock | twilio | msg91
OTP_PROVIDER=mock
JWT_SECRET=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# AI Model Configuration
VECTOR_STORE=faiss
